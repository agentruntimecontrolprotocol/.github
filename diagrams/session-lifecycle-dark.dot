digraph SessionLifecycle {
  rankdir=LR;
  bgcolor="transparent";
  compound=true;
  fontname="Helvetica";
  splines=spline;
  nodesep=0.38;
  ranksep=0.65;
  pad="0.35,0.25";

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#334155",
    color="#475569",
    fontname="Helvetica",
    fontsize=11,
    fontcolor="#F1F5F9",
    margin="0.22,0.11",
    penwidth=1.0
  ];

  edge [
    fontname="Helvetica",
    fontsize=9,
    fontcolor="#94A3B8",
    color="#64748B",
    penwidth=1.1,
    arrowsize=0.75,
    arrowhead=vee
  ];

  Connecting [
    label=<<FONT POINT-SIZE="12"><B>Connecting</B></FONT>>,
    fillcolor="#3B82F6", color="#2563EB",
    fontcolor="white", penwidth=1.4
  ];

  subgraph cluster_handshake {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>Handshake</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#0F172A";
    color="#334155";
    fontname="Helvetica";
    fontcolor="#94A3B8";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    Negotiating    [label="Negotiating"];
    Authenticating [label="Authenticating"];
  }

  subgraph cluster_live {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>Live</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#1E293B";
    color="#334155";
    fontname="Helvetica";
    fontcolor="#94A3B8";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    Active [
      label=<<FONT POINT-SIZE="12"><B>Active</B></FONT>>,
      fillcolor="#F59E0B", color="#D97706",
      fontcolor="white", penwidth=1.4
    ];

    Refreshing [label="Refreshing"];
  }

  Closing [label="Closing"];
  Closed  [label="Closed"];

  // PRIMARY SPINE — handshake → active
  edge [color="#94A3B8", penwidth=1.2];
  Connecting    -> Negotiating    [label="session.open"];
  Negotiating   -> Authenticating [label="challenge"];
  Authenticating -> Active        [label="accepted", lhead=cluster_live];
  Negotiating   -> Active         [label="accepted", lhead=cluster_live];
  Active        -> Closing        [label="session.close"];
  Closing       -> Closed;

  // SECONDARY WIRING — refresh + terminal paths
  edge [color="#475569", penwidth=1.0];
  Active         -> Refreshing    [label="refresh"];
  Refreshing     -> Active        [label="re-authenticated"];
  Authenticating -> Closed        [label="rejected"];
  Refreshing     -> Closed        [label="evicted"];
  Active         -> Closed        [label="timeout"];

  // FEEDBACK — durable resume
  Closed -> Connecting [
    style=dashed, color="#F472B6", penwidth=1.1,
    constraint=false,
    label=<<FONT COLOR="#F472B6">resume (durable)</FONT>>, fontsize=9
  ];
}
