digraph ARCP {
  rankdir=TB;
  bgcolor="transparent";
  compound=true;
  fontname="Helvetica";
  splines=spline;
  nodesep=0.32;
  ranksep=0.55;
  pad="0.35,0.25";

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="white",
    color="#CBD5E1",
    fontname="Helvetica",
    fontsize=11,
    fontcolor="#1F2937",
    margin="0.22,0.11",
    penwidth=1.0
  ];

  edge [
    fontname="Helvetica",
    fontsize=9,
    fontcolor="#64748B",
    color="#94A3B8",
    penwidth=1.1,
    arrowsize=0.75,
    arrowhead=vee
  ];

  Client [
    label=<<FONT POINT-SIZE="12"><B>ARCPClient</B></FONT>>,
    fillcolor="#3B82F6", color="#2563EB",
    fontcolor="white", penwidth=1.4
  ];

  subgraph cluster_transport {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>Transport</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#F1F5F9";
    color="#E2E8F0";
    fontname="Helvetica";
    fontcolor="#475569";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    WS    [label="WebSocket"];
    StdIO [label="stdio"];
    InMem [label="in-memory"];

    WS -> StdIO -> InMem [style=invis];
    { rank=same; WS; StdIO; InMem; }
  }

  subgraph cluster_runtime {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>ARCPRuntime</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#F8FAFC";
    color="#E2E8F0";
    fontname="Helvetica";
    fontcolor="#475569";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    Hand [label="HandshakeDriver"];

    Disp [
      label=<<FONT POINT-SIZE="12"><B>Dispatcher</B></FONT>>,
      fillcolor="#F59E0B", color="#D97706",
      fontcolor="white", penwidth=1.4
    ];

    Jobs    [label="JobManager"];
    Streams [label="StreamManager"];
    Subs    [label="SubscriptionManager"];
    Leases  [label="LeaseManager"];
    Arts    [label="ArtifactStore"];
    Pending [label="PendingRequestRegistry"];

    Log [
      label=<<FONT POINT-SIZE="10">EventLog</FONT><BR/><FONT POINT-SIZE="8" COLOR="#94A3B8">SQLite</FONT>>,
      shape=cylinder, fillcolor="#FAFBFC"
    ];
  }

  Client -> StdIO [dir=both, label="envelopes", lhead=cluster_transport];
  StdIO  -> Hand  [dir=both, label="envelopes", ltail=cluster_transport];

  Hand -> Disp [penwidth=1.4, color="#64748B"];

  edge [color="#64748B", penwidth=1.2];
  Disp -> Jobs;
  Disp -> Subs;
  Disp -> Leases;
  Disp -> Arts;
  Disp -> Pending;

  edge [color="#CBD5E1", penwidth=1.0];
  Jobs -> Streams;
  Subs -> Log;
  Jobs -> Pending;

  Pending -> Disp [
    style=dashed, color="#F472B6", penwidth=1.1,
    constraint=false,
    label=<<FONT COLOR="#DB2777">resolve</FONT>>, fontsize=9
  ];
}
